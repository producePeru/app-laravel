)
SELECT
    2 AS unidad,

    MONTH(
        STR_TO_DATE(
            JSON_UNQUOTE(JSON_EXTRACT(dates, '$[0]')),
            '%Y-%m-%d'
        )
    ) AS mes,

    dates AS fechas,
    JSON_LENGTH(dates) AS cantidad_dias,
    7 AS tipo_actividad_id,
    16 AS nombre_actividad_id,
    title AS tema,
    city_id AS region,
    province_id AS provincia,
    district_id AS distrito,
    place AS lugar,
    NULL AS entidad_organizadora,
