INSERT INTO empresarios (
    ruc,
    razon_social,
    nombre_comercial,
    sector_economico_id,
    rubro_id,
    actividad_comercial_id,
    actividad_comercial_nombre,
    pais_id,
    region_id,
    provincia_id,
    distrito_id,
    direccion,
    tipo_documento_id,
    numero_dni,
    apellido_paterno,
    apellido_materno,
    nombres,
    genero_id,
    discapacidad,
    celular,
    correo_electronico,
    cargo_empresa_id,
    fecha_nacimiento,
    edad,
    como_entero
)
SELECT
    NULLIF(u.ruc, ''),
    NULLIF(u.socialReason, ''),
    NULLIF(u.comercialName, ''),

    NULLIF(u.economicsector_id, 0),

    NULLIF(u.category_id, 0),

    NULLIF(u.comercialactivity_id, 0),

    NULL AS actividad_comercial_nombre,

    NULL AS pais_id,

    NULLIF(u.city_id, 0),
    NULLIF(u.province_id, 0),
    NULLIF(u.district_id, 0),

    NULLIF(u.address, ''),

    NULLIF(u.typedocument_id, 0),

    NULLIF(u.documentnumber, ''),

    NULLIF(u.lastname, ''),
    NULLIF(u.middlename, ''),
    NULLIF(u.name, ''),

    NULLIF(u.gender_id, 0),
    NULLIF(u.sick, 0),

    NULLIF(u.phone, ''),
    NULLIF(u.email, ''),

    NULL AS cargo_empresa_id,

    u.birthday,
    u.age,

    NULL AS como_entero

FROM ugse_postulantes u

WHERE NOT EXISTS (
    SELECT 1
    FROM empresarios e
    WHERE
        (
            e.ruc IS NOT NULL
            AND u.ruc IS NOT NULL
            AND e.ruc = u.ruc
        )
        OR
        (
            e.numero_dni IS NOT NULL
            AND u.documentnumber IS NOT NULL
            AND e.numero_dni = u.documentnumber
        )
);



